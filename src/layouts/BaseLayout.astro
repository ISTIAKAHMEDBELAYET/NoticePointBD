---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';

const {
  title = 'NoticePointBD - Jobs, Admissions, Results, Blog',
  description = 'Latest Bangladesh job circulars, admission notices, and results updates.',
  image = '/images/logo.png',
  type = 'website',
  noindex = false,
  schema = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? new URL('https://noticepointbd.pages.dev')).toString();
---

<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      schema={schema}
    />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2278011013110319"
      crossorigin="anonymous"
    ></script>
    <slot name="head" />
  </head>
  <body class="bg-gray-50 text-gray-900">
    <Header />
    <main class="mx-auto min-h-[60vh] w-full max-w-6xl px-4">
      <slot />
    </main>
    <Footer />
  </body>
</html>
