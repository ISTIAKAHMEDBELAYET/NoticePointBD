---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';

const {
  title = 'NoticePointBD - Jobs, Admissions, Results, Blog',
  description = 'Latest Bangladesh job circulars, admission notices, and results updates.',
  image = '/images/logo-animated.svg',
  type = 'website',
  noindex = false,
  schema = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? new URL('https://noticepointbd.pages.dev')).toString();
---

<html lang="bn">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      schema={schema}
    />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2278011013110319"
      crossorigin="anonymous"
    ></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class="bg-[#efefef] text-[#1f2937]" style="font-family:'Hind Siliguri',sans-serif;">
    <Header />
    <main class="mx-auto min-h-[60vh] w-full max-w-[1200px] px-2 md:px-3">
      <slot />
    </main>
    <Footer />
  </body>
</html>
