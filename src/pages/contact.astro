---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="যোগাযোগ - NoticePointBD" description="NoticePointBD এর সাথে যোগাযোগের উপায়।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">যোগাযোগ</h1>
    <p class="mb-3 text-gray-700">
      ভুল তথ্য সংশোধন, কপিরাইট ইস্যু, বিজ্ঞাপন বা ব্যবসায়িক যোগাযোগের জন্য ইমেইল করুন।
    </p>
    <p class="mb-3 text-gray-800">
      Email: <a class="text-blue-700 hover:underline" href="mailto:contact@noticepointbd.com">contact@noticepointbd.com</a>
    </p>
    <p class="text-gray-700">
      সাধারণত 24-72 ঘণ্টার মধ্যে উত্তর দেওয়ার চেষ্টা করা হয়।
    </p>
  </article>
</BaseLayout>
