---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="আমাদের সম্পর্কে - NoticePointBD" description="NoticePointBD সম্পর্কে তথ্য এবং আমাদের এডিটোরিয়াল লক্ষ্য।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">আমাদের সম্পর্কে</h1>
    <p class="mb-3 text-gray-700">
      NoticePointBD হলো বাংলাদেশের চাকরি, ভর্তি, ফলাফল ও তথ্যভিত্তিক আপডেট প্রকাশের একটি ইনফরমেশন প্ল্যাটফর্ম।
    </p>
    <p class="mb-3 text-gray-700">
      আমরা মূল সোর্স থেকে তথ্য সংগ্রহ করে পাঠকের জন্য সহজ ভাষায় উপস্থাপন করি।
    </p>
    <p class="mb-3 text-gray-700">
      আমরা সরাসরি চাকরির আবেদন নেই না এবং কোনো নিয়োগ প্রক্রিয়া পরিচালনা করি না।
    </p>
    <p class="text-gray-700">
      আবেদন করার আগে অবশ্যই অফিসিয়াল বিজ্ঞপ্তি বা ওয়েবসাইট যাচাই করে নিন।
    </p>
  </article>
</BaseLayout>
