---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="টার্মস অ্যান্ড কন্ডিশনস - NoticePointBD" description="NoticePointBD ব্যবহারের শর্তাবলি।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">টার্মস অ্যান্ড কন্ডিশনস</h1>
    <p class="mb-3 text-gray-700">
      NoticePointBD ব্যবহার করলে আপনি আইনসঙ্গতভাবে সাইট ব্যবহার করতে সম্মত হন।
    </p>
    <p class="mb-3 text-gray-700">
      এখানে প্রকাশিত সকল তথ্য শুধুমাত্র ইনফরমেশনাল উদ্দেশ্যে। কোনো সময় পূর্ব ঘোষণা ছাড়াই কনটেন্ট আপডেট/পরিবর্তন করা হতে পারে।
    </p>
    <p class="mb-3 text-gray-700">
      External লিংকে গেলে সেই সাইটের কনটেন্ট বা পলিসির দায় আমাদের নয়।
    </p>
    <p class="text-gray-700">
      সাইট ব্যবহারের ধারাবাহিকতা মানে আপডেটেড টার্মস গ্রহণ করা।
    </p>
  </article>
</BaseLayout>
