---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="প্রাইভেসি পলিসি - NoticePointBD" description="NoticePointBD এর প্রাইভেসি পলিসি ও ডেটা ব্যবহারের নিয়মাবলি।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">প্রাইভেসি পলিসি</h1>
    <p class="mb-4 text-gray-700">শেষ আপডেট: April 20, 2026</p>
    <p class="mb-3 text-gray-700">
      NoticePointBD ব্যবহার করার সময় আমরা সীমিত কিছু non-personal তথ্য (browser type, device, pages visited) সংগ্রহ করতে পারি।
    </p>
    <p class="mb-3 text-gray-700">
      বিজ্ঞাপন দেখানোর জন্য আমরা Google AdSense এবং অন্যান্য third-party vendor ব্যবহার করতে পারি। এসব সেবা cookies ব্যবহার করে ব্যবহারকারীর আগের ভিজিটের ভিত্তিতে বিজ্ঞাপন দেখাতে পারে।
    </p>
    <p class="mb-3 text-gray-700">
      Google এর personalized ads বন্ধ করতে Google Ads Settings ব্যবহার করতে পারবেন।
    </p>
    <p class="mb-3 text-gray-700">
      আমরা ব্যবহারকারীর ব্যক্তিগত তথ্য বিক্রি করি না। ইমেইলে যোগাযোগ করলে শুধুমাত্র উত্তর দেওয়ার জন্য সেই তথ্য ব্যবহার করা হয়।
    </p>
    <p class="text-gray-700">
      যেকোনো প্রশ্নের জন্য: <a class="text-blue-700 hover:underline" href="mailto:contact@noticepointbd.com">contact@noticepointbd.com</a>
    </p>
  </article>
</BaseLayout>
