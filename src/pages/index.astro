---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import HotStrip from '../components/HotStrip.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import Sidebar from '../components/Sidebar.astro';
import { POSTS_PER_PAGE, sortPostsByDate, getUniqueCategories, paginatePosts } from '../lib/content-utils';

const allPosts = sortPostsByDate((await Astro.glob('../content/**/*.md')).filter((post) => post.frontmatter?.slug));
const categories = getUniqueCategories(allPosts);
const hotPosts = allPosts.filter((post) => post.frontmatter?.hot).slice(0, 3);
const recentPosts = allPosts.slice(0, 5);
const { pagedPosts, totalPages } = paginatePosts(allPosts, 1, POSTS_PER_PAGE);
---

<BaseLayout
  title="NoticePointBD - বাংলাদেশের সর্বশেষ চাকরি, ভর্তি ও ফলাফল"
  description="বাংলাদেশের সর্বশেষ চাকরির খবর, ভর্তি বিজ্ঞপ্তি, ফলাফল ও গুরুত্বপূর্ণ আপডেট এক জায়গায়।"
>
  <section class="my-6">
    <div class="np-panel np-fade-up mb-5 border-l-4 border-l-blue-600 p-4">
      <h1 class="mb-1 text-3xl font-bold text-blue-800">সর্বশেষ আপডেট</h1>
      <p class="text-gray-700">চাকরি, ভর্তি, ফলাফল ও প্রয়োজনীয় গাইড - সব একসাথে।</p>
    </div>

    <FilterBar categories={categories} />
    <div class="grid items-start gap-5 lg:grid-cols-[minmax(0,1fr)_300px]">
      <div>
        <HotStrip posts={hotPosts} />
        <div id="feed-list" class="space-y-5">
          {pagedPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
        <Pagination currentPage={1} totalPages={totalPages} basePath="" />
      </div>
      <Sidebar categories={categories} recentPosts={recentPosts} />
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('filter-form');
  const cards = [...document.querySelectorAll('[data-post-card]')];
  const categorySelect = document.getElementById('filter-category');
  const deadlineSelect = document.getElementById('filter-deadline');
  const dateSelect = document.getElementById('filter-date');

  const now = new Date();
  const daysDiff = (target) => Math.ceil((target.getTime() - now.getTime()) / 86400000);

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const category = categorySelect?.value ?? '';
    const deadline = deadlineSelect?.value ?? '';
    const published = dateSelect?.value ?? '';

    cards.forEach((card) => {
      const cardCategories = (card.dataset.categories ?? '').split(',').filter(Boolean);
      const cardDate = card.dataset.date ? new Date(card.dataset.date) : null;
      const cardDeadline = card.dataset.deadline ? new Date(card.dataset.deadline) : null;

      const matchCategory = !category || cardCategories.includes(category);
      const matchPublished = !published || (cardDate && daysDiff(cardDate) <= Number(published) && daysDiff(cardDate) >= -3650);
      const matchDeadline =
        !deadline ||
        (deadline === 'today' && cardDeadline && daysDiff(cardDeadline) === 0) ||
        (deadline !== 'today' && cardDeadline && daysDiff(cardDeadline) <= Number(deadline) && daysDiff(cardDeadline) >= 0);

      card.style.display = matchCategory && matchPublished && matchDeadline ? '' : 'none';
    });
  });
</script>
