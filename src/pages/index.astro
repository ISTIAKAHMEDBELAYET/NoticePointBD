---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import HotStrip from '../components/HotStrip.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import Sidebar from '../components/Sidebar.astro';
import { POSTS_PER_PAGE, sortPostsByDate, getUniqueCategories, paginatePosts } from '../lib/content-utils';

const allPosts = sortPostsByDate((await Astro.glob('../content/**/*.md')).filter((post) => post.frontmatter?.slug && ['job','admission','result'].includes(post.frontmatter?.type)));
const categories = getUniqueCategories(allPosts);
// Hot Jobs: top 10 most viewed job posts in last 12 hours (per visitor)
const recentPosts = allPosts.slice(0, 5);
const jobPosts = allPosts.filter((post) => post.frontmatter?.type === 'job');
const { pagedPosts, totalPages } = paginatePosts(allPosts, 1, POSTS_PER_PAGE);
---

<BaseLayout
  title="NoticePointBD - বাংলাদেশের সর্বশেষ চাকরি, ভর্তি ও ফলাফল"
  description="বাংলাদেশের সর্বশেষ চাকরির খবর, ভর্তি বিজ্ঞপ্তি, ফলাফল ও গুরুত্বপূর্ণ আপডেট এক জায়গায়।"
>
  <section class="my-6">
    <!-- Removed np-panel np-fade-up mb-5 border-l-4 border-l-blue-600 p-5 section -->
    <!-- Removed Latest Update banner and guide text -->

    <FilterBar categories={categories} />
    <div class="grid items-start gap-6 lg:grid-cols-[minmax(0,70%)_minmax(0,30%)]">
      <div>
        <div id="hot-strip-mount"></div>
          <div id="hot-strip-mount"></div>
        <script>
        // Track job post views in localStorage
        function trackJobView(slug) {
          const key = 'npbd_job_views';
          const now = Date.now();
          let views = JSON.parse(localStorage.getItem(key) || '{}');
          if (!views[slug]) views[slug] = [];
          views[slug].push(now);
          // Remove views older than 12 hours
          for (const s in views) {
            views[s] = views[s].filter(ts => now - ts < 12 * 60 * 60 * 1000);
            if (views[s].length === 0) delete views[s];
          }
          localStorage.setItem(key, JSON.stringify(views));
        }

        // Attach view tracking to all job post links
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('[data-job-slug]').forEach(el => {
            el.addEventListener('click', () => {
              trackJobView(el.getAttribute('data-job-slug'));
            });
          });

    // Hot Jobs logic
    const key = 'npbd_job_views';
    const views = JSON.parse(localStorage.getItem(key) || '{}');
    const jobs = Array.from(document.querySelectorAll('[data-job-slug]')).map(el => ({
      slug: el.getAttribute('data-job-slug'),
      title: el.getAttribute('data-job-title'),
      url: el.getAttribute('href'),
    }));
    // Count views
    jobs.forEach(j => { j.count = (views[j.slug] || []).length; });
    jobs.sort((a, b) => b.count - a.count);
    const top10 = jobs.slice(0, 10);
    // Render HotStrip
    const mount = document.getElementById('hot-strip-mount');
    if (mount) {
      mount.innerHTML = `<div class='hot-strip-dark'>${top10.map(j => `
        <a href="${j.url}" data-job-slug="${j.slug}" class="flex items-center gap-2 rounded-[10px] border px-3 py-2 text-[16px] font-semibold hover:bg-yellow-900">
          <span class="rounded px-2 py-0.5 text-xs animate-blink">হট</span>
          <span>${j.title}</span>
        </a>
      `).join('')}</div>`;
    }
        });
        </script>
        <div id="feed-list" class="space-y-5">
          {pagedPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
        <Pagination currentPage={1} totalPages={totalPages} basePath="" />
      </div>
      <Sidebar categories={categories} recentPosts={recentPosts} />
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('filter-form');
  const cards = [...document.querySelectorAll('[data-post-card]')];
  const keywordInput = document.getElementById('filter-keyword');
  const categorySelect = document.getElementById('filter-category');
  const deadlineSelect = document.getElementById('filter-deadline');
  const dateSelect = document.getElementById('filter-date');

  const MS_PER_DAY = 86400000;
  const now = new Date();
  const diffInDays = (from, to) => Math.floor((to.getTime() - from.getTime()) / MS_PER_DAY);

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const keyword = (keywordInput?.value ?? '').trim().toLowerCase();
    const category = categorySelect?.value ?? '';
    const deadline = deadlineSelect?.value ?? '';
    const published = dateSelect?.value ?? '';

    cards.forEach((card) => {
      const cardCategories = (card.dataset.categories ?? '').split(',').filter(Boolean);
      const titleText = card.dataset.title ?? '';
      const descriptionText = card.dataset.description ?? '';
      const cardDate = card.dataset.date ? new Date(card.dataset.date) : null;
      const cardDeadline = card.dataset.deadline ? new Date(card.dataset.deadline) : null;

      const publishedAgo = cardDate ? diffInDays(cardDate, now) : null;
      const deadlineIn = cardDeadline ? diffInDays(now, cardDeadline) : null;

      const matchKeyword = !keyword || titleText.includes(keyword) || descriptionText.includes(keyword);
      const matchCategory = !category || cardCategories.includes(category);
      const matchPublished = !published || (publishedAgo !== null && publishedAgo >= 0 && publishedAgo <= Number(published));
      const matchDeadline =
        !deadline ||
        (deadline === 'today' && deadlineIn === 0) ||
        (deadline !== 'today' && deadlineIn !== null && deadlineIn >= 0 && deadlineIn <= Number(deadline));

      card.style.display = matchKeyword && matchCategory && matchPublished && matchDeadline ? '' : 'none';
    });
  });
</script>
