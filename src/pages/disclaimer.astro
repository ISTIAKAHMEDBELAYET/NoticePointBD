---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ডিসক্লেইমার - NoticePointBD" description="NoticePointBD এর দায়-অস্বীকার নীতি।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">ডিসক্লেইমার</h1>
    <p class="mb-3 text-gray-700">
      NoticePointBD কোনো সরকারি প্রতিষ্ঠান, নিয়োগ বোর্ড বা বিশ্ববিদ্যালয়ের অফিসিয়াল সাইট নয়।
    </p>
    <p class="mb-3 text-gray-700">
      আমরা তথ্য আপডেট রাখার চেষ্টা করি, তবে কনটেন্টে ভুল বা বিলম্ব হতে পারে।
    </p>
    <p class="text-gray-700">
      আবেদন, ফলাফল বা ভর্তি সংক্রান্ত সিদ্ধান্ত নেওয়ার আগে অবশ্যই অফিসিয়াল নোটিশ যাচাই করুন।
    </p>
  </article>
</BaseLayout>
