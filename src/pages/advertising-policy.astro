---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="বিজ্ঞাপন নীতি - NoticePointBD" description="NoticePointBD এ বিজ্ঞাপন প্রদর্শনের নীতি ও নির্দেশনা।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">বিজ্ঞাপন নীতি</h1>
    <p class="mb-3 text-gray-700">
      NoticePointBD-তে Google AdSense এবং অনুমোদিত তৃতীয় পক্ষের বিজ্ঞাপন নেটওয়ার্কের বিজ্ঞাপন প্রদর্শিত হতে পারে।
    </p>
    <p class="mb-3 text-gray-700">
      বিজ্ঞাপন কনটেন্ট এবং এড ক্লিকের পর বাহ্যিক সাইটের কার্যক্রমের জন্য NoticePointBD দায়ী নয়।
    </p>
    <p class="mb-3 text-gray-700">
      আমরা বিভ্রান্তিকর, ক্ষতিকর বা নীতিবিরোধী বিজ্ঞাপন অনুমোদন করি না। সমস্যা দেখলে আমাদেরকে রিপোর্ট করুন।
    </p>
    <p class="text-gray-700">
      বিজ্ঞাপন সংক্রান্ত যোগাযোগ: <a class="text-blue-700 hover:underline" href="mailto:contact@noticepointbd.com">contact@noticepointbd.com</a>
    </p>
  </article>
</BaseLayout>
