---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterBar from '../../components/FilterBar.astro';
import HotStrip from '../../components/HotStrip.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import WidgetArea from '../../components/WidgetArea.astro';
import { POSTS_PER_PAGE, sortPostsByDate, getUniqueCategories, paginatePosts } from '../../lib/content-utils';

export async function getStaticPaths() {
  const posts = sortPostsByDate((await Astro.glob('../../content/**/*.md')).filter((post) => post.frontmatter?.slug));
  const categoryMap = new Map();

  for (const post of posts) {
    const categories = Array.isArray(post.frontmatter?.categories) ? post.frontmatter.categories : [];
    for (const category of categories) {
      if (!categoryMap.has(category)) {
        categoryMap.set(category, []);
      }
      categoryMap.get(category).push(post);
    }
  }

  return Array.from(categoryMap.entries()).map(([category, categoryPosts]) => ({
    params: { category },
    props: { category, categoryPosts, allPosts: posts },
  }));
}

const { category, categoryPosts, allPosts } = Astro.props;
const categories = getUniqueCategories(allPosts);
const recentPosts = allPosts.slice(0, 5);
const { pagedPosts, totalPages } = paginatePosts(categoryPosts, 1, POSTS_PER_PAGE);
const hotPosts = allPosts.filter((post) => post.frontmatter?.hot).slice(0, 3);
---

<BaseLayout
  title={`Category: ${category} - NoticePointBD`}
  description={`Browse all ${category} posts on NoticePointBD.`}
>
  <section class="my-8">
    <h1 class="mb-6 text-3xl font-bold capitalize">{category}</h1>
    <FilterBar categories={categories} />
    <HotStrip posts={hotPosts} />
    <div class="space-y-6">
      {pagedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/category/${category}`} />
    <WidgetArea categories={categories} recentPosts={recentPosts} />
  </section>
</BaseLayout>
