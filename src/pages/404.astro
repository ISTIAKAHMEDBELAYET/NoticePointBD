---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found | NoticePointBD" description="The page you requested was not found." noindex={true}>
  <section class="mx-auto my-16 max-w-xl rounded-lg bg-white p-8 text-center shadow-sm">
    <h1 class="mb-3 text-4xl font-bold">404</h1>
    <p class="mb-4 text-gray-700">The page you are looking for does not exist.</p>
    <a class="font-semibold text-blue-700 hover:underline" href="/">Back to Home</a>
  </section>
</BaseLayout>
