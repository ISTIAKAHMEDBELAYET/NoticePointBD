---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="কুকি পলিসি - NoticePointBD" description="NoticePointBD এর cookie ব্যবহারের নীতি।">
  <article class="mx-auto my-8 max-w-4xl border border-gray-300 bg-white p-5">
    <h1 class="mb-4 text-3xl font-bold">কুকি পলিসি</h1>
    <p class="mb-3 text-gray-700">
      আমাদের ওয়েবসাইটে user experience উন্নত করা, analytics এবং বিজ্ঞাপন দেখানোর জন্য cookies ব্যবহার করা হতে পারে।
    </p>
    <p class="mb-3 text-gray-700">
      Google AdSense সহ third-party vendor cookies ব্যবহার করে আপনার আগের browsing activity অনুযায়ী বিজ্ঞাপন দেখাতে পারে।
    </p>
    <p class="mb-3 text-gray-700">
      আপনি browser settings থেকে cookies নিয়ন্ত্রণ বা ব্লক করতে পারবেন। cookies বন্ধ করলে কিছু ফিচার স্বাভাবিকভাবে কাজ নাও করতে পারে।
    </p>
    <p class="text-gray-700">
      বিস্তারিত জানতে দেখুন: <a class="text-blue-700 hover:underline" href="/privacy-policy/">Privacy Policy</a>
    </p>
  </article>
</BaseLayout>
