---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await Astro.glob('../content/**/*.md')).filter((post) => post.frontmatter?.slug);
const searchData = posts.map((post) => ({
  title: post.frontmatter?.title ?? 'Untitled',
  slug: post.frontmatter?.slug ?? '',
  description: post.frontmatter?.description ?? '',
  type: post.frontmatter?.type ?? 'post',
  date: post.frontmatter?.date ?? '',
  categories: post.frontmatter?.categories ?? [],
}));
---

<BaseLayout title="Smart Search - NoticePointBD" description="Fuzzy search jobs, admissions, results, and blog posts.">
  <section class="mx-auto my-8 max-w-4xl rounded-lg bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-3xl font-bold">Smart Search</h1>
    <input
      id="search-input"
      type="search"
      placeholder="Search jobs, admission, result, blog..."
      class="mb-5 w-full rounded border border-gray-300 px-4 py-2 focus:border-blue-500 focus:outline-none"
    />
    <p id="search-count" class="mb-3 text-sm text-gray-500"></p>
    <ul id="search-results" class="space-y-3"></ul>
  </section>

  <script type="module" define:vars={{ searchData }}>
    import Fuse from 'fuse.js';

    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const count = document.getElementById('search-count');
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') ?? '';

    const fuse = new Fuse(searchData, {
      keys: ['title', 'description', 'categories', 'type'],
      threshold: 0.35,
      includeScore: true,
    });

    const render = (items) => {
      count.textContent = `${items.length} result(s) found`;
      results.innerHTML = items
        .map((item) => {
          const categories = (item.categories ?? [])
            .map((category) => `<span class="rounded bg-gray-100 px-2 py-0.5 text-xs">${category}</span>`)
            .join(' ');

          return `<li class="rounded border border-gray-200 p-4">
            <div class="mb-1 flex flex-wrap items-center gap-2 text-xs">
              <span class="rounded bg-blue-100 px-2 py-0.5 text-blue-700">${item.type}</span>
              <span class="text-gray-500">${item.date}</span>
              ${categories}
            </div>
            <a class="text-lg font-semibold text-blue-700 hover:underline" href="/${item.slug}/">${item.title}</a>
            <p class="mt-1 text-sm text-gray-600">${item.description}</p>
          </li>`;
        })
        .join('');
    };

    const doSearch = (query) => {
      if (!query.trim()) {
        render(searchData);
        return;
      }
      const found = fuse.search(query).map((result) => result.item);
      render(found);
    };

    input.value = initialQuery;
    doSearch(initialQuery);

    input?.addEventListener('input', (event) => {
      doSearch(event.target.value);
    });
  </script>
</BaseLayout>
