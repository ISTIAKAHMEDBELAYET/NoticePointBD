---
const chakriLinks = [
  ['government-jobs', 'সরকারি চাকরি'],
  ['bank-jobs', 'ব্যাংক চাকরি'],
  ['private-jobs', 'প্রাইভেট চাকরি'],
  ['defence-jobs', 'ডিফেন্স চাকরি'],
  ['ngo-jobs', 'এনজিও চাকরি'],
  ['university-jobs', 'বিশ্ববিদ্যালয় চাকরি'],
  ['hot-jobs', 'হট জবস'],
  ['teletalk-application', 'অনলাইন আবেদন'],
];

const vortiLinks = [
  ['admission', 'সকল ভর্তি'],
  ['university-admission', 'বিশ্ববিদ্যালয় ভর্তি'],
  ['medical-admission', 'মেডিকেল ভর্তি'],
  ['college-admission', 'কলেজ ভর্তি'],
  ['school-admission', 'স্কুল ভর্তি'],
];

const folafolLinks = [
  ['result', 'সকল ফলাফল'],
  ['ssc-result', 'এসএসসি ফলাফল'],
  ['hsc-result', 'এইচএসসি ফলাফল'],
  ['university-result', 'বিশ্ববিদ্যালয় ফলাফল'],
  ['job-exam-result', 'চাকরি পরীক্ষার ফলাফল'],
];
---

<header class="sticky top-0 z-50 border-b border-blue-100 bg-white">
  <div class="mx-auto flex max-w-[1100px] items-center justify-between px-3 py-3">
    <a class="flex items-center gap-2" href="/">
      <img src="/images/logo.png" alt="NoticePointBD লোগো" class="h-10 w-auto" loading="eager" />
      <span class="text-lg font-bold text-blue-700 md:text-xl">NoticePointBD</span>
    </a>
    <button id="mobile-menu-button" class="rounded border px-3 py-1 text-sm md:hidden">মেনু</button>
    <nav class="hidden items-center gap-1 text-sm font-medium text-gray-800 md:flex">
      <a class="rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700" href="/">হোম</a>
      <details class="group relative">
        <summary class="cursor-pointer list-none rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700">চাকরি</summary>
        <ul class="absolute left-0 mt-1 w-56 rounded border border-gray-200 bg-white p-2 shadow-lg">
          {chakriLinks.map(([slug, label]) => (
            <li><a class="block rounded px-2 py-1 hover:bg-gray-100" href={`/category/${slug}/`}>{label}</a></li>
          ))}
        </ul>
      </details>
      <details class="group relative">
        <summary class="cursor-pointer list-none rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700">ভর্তি</summary>
        <ul class="absolute left-0 mt-1 w-56 rounded border border-gray-200 bg-white p-2 shadow-lg">
          {vortiLinks.map(([slug, label]) => (
            <li><a class="block rounded px-2 py-1 hover:bg-gray-100" href={`/category/${slug}/`}>{label}</a></li>
          ))}
        </ul>
      </details>
      <details class="group relative">
        <summary class="cursor-pointer list-none rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700">ফলাফল</summary>
        <ul class="absolute left-0 mt-1 w-56 rounded border border-gray-200 bg-white p-2 shadow-lg">
          {folafolLinks.map(([slug, label]) => (
            <li><a class="block rounded px-2 py-1 hover:bg-gray-100" href={`/category/${slug}/`}>{label}</a></li>
          ))}
        </ul>
      </details>
      <a class="rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700" href="/category/blog/">ব্লগ</a>
      <details class="group relative">
        <summary class="cursor-pointer list-none rounded px-2 py-1 hover:bg-blue-50 hover:text-blue-700">টুলস</summary>
        <ul class="absolute left-0 mt-1 w-56 rounded border border-gray-200 bg-white p-2 shadow-lg">
          <li><a class="block rounded px-2 py-1 hover:bg-gray-100" href="/age-calculator/">Age Calculator</a></li>
          <li><a class="block rounded px-2 py-1 hover:bg-gray-100" href="/search/">Smart Search</a></li>
        </ul>
      </details>
    </nav>
  </div>

  <nav id="mobile-menu" class="mx-auto hidden max-w-[1100px] space-y-2 border-t border-gray-100 px-3 py-3 text-sm md:hidden">
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/">হোম</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/category/government-jobs/">সরকারি চাকরি</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/category/admission/">ভর্তি</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/category/result/">ফলাফল</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/search/">Smart Search</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/age-calculator/">Age Calculator</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/about/">আমাদের সম্পর্কে</a>
    <a class="block rounded px-2 py-1 hover:bg-gray-100" href="/contact/">যোগাযোগ</a>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
