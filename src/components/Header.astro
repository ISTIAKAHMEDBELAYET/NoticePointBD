---
const privateLinks = [
  ['ngo-jobs', 'এনজিও চাকরি'],
  ['pharmaceuticals-jobs', 'ফার্মাসিউটিক্যালস চাকরি'],
  ['group-company-jobs', 'গ্রুপ অব কোম্পানি চাকরি'],
];

const moreLinks = [
  ['university-jobs', 'বিশ্ববিদ্যালয় চাকরি'],
  ['defence-jobs', 'ডিফেন্স জবস'],
  ['weekly-jobs', 'সাপ্তাহিক চাকরির খবর'],
  ['search', 'Search জবস'],
  ['age-calculator', 'Age Calculator'],
];
---

<header id="masthead" class="site-header grid-container hidden border-b border-gray-300 bg-white md:block" aria-label="Site">
  <div class="inside-header grid-container">
    <div class="site-logo">
      <a href="/" rel="home">
        <img
          class="header-image is-logo-image"
          src="/images/logo-animated.svg"
          alt="NoticePointBD লোগো"
          width="390"
          height="125"
          loading="eager"
        />
      </a>
    </div>
  </div>
</header>

<nav
  class="auto-hide-sticky main-navigation grid-container has-menu-bar-items sub-menu-right"
  id="site-navigation"
  aria-label="Primary"
  itemtype="https://schema.org/SiteNavigationElement"
  itemscope
>
  <div class="inside-navigation grid-container">
    <button class="menu-toggle" aria-controls="primary-menu" aria-expanded="false">
      <span class="gp-icon icon-menu-bars" aria-hidden="true">
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
          <path d="M0 96c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24zm0 160c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24zm0 160c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24z"></path>
        </svg>
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
          <path d="M71.029 71.029c9.373-9.372 24.569-9.372 33.942 0L256 222.059l151.029-151.03c9.373-9.372 24.569-9.372 33.942 0 9.372 9.373 9.372 24.569 0 33.942L289.941 256l151.03 151.029c9.372 9.373 9.372 24.569 0 33.942-9.373 9.372-24.569 9.372-33.942 0L256 289.941l-151.029 151.03c-9.373 9.372-24.569 9.372-33.942 0-9.372-9.373-9.372-24.569 0-33.942L222.059 256 71.029 104.971c-9.372-9.373-9.372-24.569 0-33.942z"></path>
        </svg>
      </span>
      <span class="mobile-menu">মেন্যু</span>
    </button>

    <div id="primary-menu" class="main-nav">
      <ul id="menu-primary-1" class="menu sf-menu">
        <li class="menu-item current-menu-item current_page_item menu-item-home"><a href="/" aria-current="page">হোম</a></li>
        <li class="menu-item"><a href="/category/all-jobs/">সকল চাকরি</a></li>
        <li class="menu-item"><a href="/category/government-jobs/">সরকারি চাকরি</a></li>
        <li class="menu-item"><a href="/category/bank-jobs/">ব্যাংক চাকরি</a></li>

        <li class="menu-item menu-item-has-children nav-item-has-children">
          <a href="/category/private-jobs/">
            প্রাইভেট চাকরি
            <span role="presentation" class="dropdown-menu-toggle">
              <span class="gp-icon icon-arrow" aria-hidden="true">
                <svg viewBox="0 0 330 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
                  <path d="M305.913 197.085c0 2.266-1.133 4.815-2.833 6.514L171.087 335.593c-1.7 1.7-4.249 2.832-6.515 2.832s-4.815-1.133-6.515-2.832L26.064 203.599c-1.7-1.7-2.832-4.248-2.832-6.514s1.132-4.816 2.832-6.515l14.162-14.163c1.7-1.699 3.966-2.832 6.515-2.832 2.266 0 4.815 1.133 6.515 2.832l111.316 111.317 111.316-111.317c1.7-1.699 4.249-2.832 6.515-2.832s4.815 1.133 6.515 2.832l14.162 14.163c1.7 1.7 2.833 4.249 2.833 6.515z"></path>
                </svg>
              </span>
            </span>
          </a>
          <ul class="sub-menu" id="menu-item-private-sub-menu">
            {privateLinks.map(([slug, label]) => (
              <li class="menu-item"><a href={`/category/${slug}/`}>{label}</a></li>
            ))}
          </ul>
        </li>

        <li class="menu-item"><a href="/category/teletalk-application/">অনলাইন আবেদন</a></li>
        <li class="menu-item"><a href="/category/hot-jobs/">হট জবস</a></li>
        <li class="menu-item"><a href="/category/notice/">নোটিশ</a></li>

        <li class="menu-item menu-item-has-children nav-item-has-children">
          <a href="#">
            আরও
            <span role="presentation" class="dropdown-menu-toggle">
              <span class="gp-icon icon-arrow" aria-hidden="true">
                <svg viewBox="0 0 330 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
                  <path d="M305.913 197.085c0 2.266-1.133 4.815-2.833 6.514L171.087 335.593c-1.7 1.7-4.249 2.832-6.515 2.832s-4.815-1.133-6.515-2.832L26.064 203.599c-1.7-1.7-2.832-4.248-2.832-6.514s1.132-4.816 2.832-6.515l14.162-14.163c1.7-1.699 3.966-2.832 6.515-2.832 2.266 0 4.815 1.133 6.515 2.832l111.316 111.317 111.316-111.317c1.7-1.699 4.249-2.832 6.515-2.832s4.815 1.133 6.515 2.832l14.162 14.163c1.7 1.7 2.833 4.249 2.833 6.515z"></path>
                </svg>
              </span>
            </span>
          </a>
          <ul class="sub-menu" id="menu-item-more-sub-menu">
            {moreLinks.map(([slug, label]) => (
              <li class="menu-item"><a href={slug === 'search' || slug === 'age-calculator' ? `/${slug}/` : `/category/${slug}/`}>{label}</a></li>
            ))}
          </ul>
        </li>
      </ul>
    </div>

    <div class="menu-bar-items">
      <span class="menu-bar-item">
        <a href="/search/" aria-label="Open search">
          <span class="gp-icon icon-search" aria-hidden="true">
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M208 48c-88.366 0-160 71.634-160 160s71.634 160 160 160 160-71.634 160-160S296.366 48 208 48zM0 208C0 93.125 93.125 0 208 0s208 93.125 208 208c0 48.741-16.765 93.566-44.843 129.024l133.826 134.018c9.366 9.379 9.355 24.575-.025 33.941-9.379 9.366-24.575 9.355-33.941-.025L337.238 370.987C301.747 399.167 256.839 416 208 416 93.125 416 0 322.875 0 208z"></path>
            </svg>
          </span>
        </a>
      </span>
    </div>
  </div>
</nav>

<nav
  id="mobile-header"
  itemtype="https://schema.org/SiteNavigationElement"
  itemscope
  class="main-navigation mobile-header-navigation has-branding has-menu-bar-items"
>
  <div class="inside-navigation grid-container grid-parent">
    <div class="site-logo mobile-header-logo">
      <a href="/" title="NoticePointBD" rel="home">
        <img src="/images/logo-animated.svg" alt="NoticePointBD" class="is-logo-image" width="390" height="125" />
      </a>
    </div>

    <button id="mobile-menu-toggle" class="menu-toggle" aria-controls="mobile-menu" aria-expanded="false">
      <span class="gp-icon icon-menu-bars" aria-hidden="true">
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
          <path d="M0 96c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24zm0 160c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24zm0 160c0-13.255 10.745-24 24-24h464c13.255 0 24 10.745 24 24s-10.745 24-24 24H24c-13.255 0-24-10.745-24-24z"></path>
        </svg>
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
          <path d="M71.029 71.029c9.373-9.372 24.569-9.372 33.942 0L256 222.059l151.029-151.03c9.373-9.372 24.569-9.372 33.942 0 9.372 9.373 9.372 24.569 0 33.942L289.941 256l151.03 151.029c9.372 9.373 9.372 24.569 0 33.942-9.373 9.372-24.569 9.372-33.942 0L256 289.941l-151.029 151.03c-9.373 9.372-24.569 9.372-33.942 0-9.372-9.373-9.372-24.569 0-33.942L222.059 256 71.029 104.971c-9.372-9.373-9.372-24.569 0-33.942z"></path>
        </svg>
      </span>
      <span class="mobile-menu">মেন্যু</span>
    </button>

    <div id="mobile-menu" class="main-nav">
      <ul class="menu sf-menu">
        <li class="menu-item"><a href="/">হোম</a></li>
        <li class="menu-item"><a href="/category/all-jobs/">সকল চাকরি</a></li>
        <li class="menu-item"><a href="/category/government-jobs/">সরকারি চাকরি</a></li>
        <li class="menu-item"><a href="/category/bank-jobs/">ব্যাংক চাকরি</a></li>
        <li class="menu-item"><a href="/category/private-jobs/">প্রাইভেট চাকরি</a></li>
        <li class="menu-item"><a href="/category/teletalk-application/">অনলাইন আবেদন</a></li>
        <li class="menu-item"><a href="/category/hot-jobs/">হট জবস</a></li>
        <li class="menu-item"><a href="/category/notice/">নোটিশ</a></li>
        <li class="menu-item"><a href="/search/">Search জবস</a></li>
        <li class="menu-item"><a href="/age-calculator/">Age Calculator</a></li>
      </ul>
    </div>

    <div class="menu-bar-items">
      <span class="menu-bar-item">
        <a href="/search/" aria-label="Open search">
          <span class="gp-icon icon-search" aria-hidden="true">
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M208 48c-88.366 0-160 71.634-160 160s71.634 160 160 160 160-71.634 160-160S296.366 48 208 48zM0 208C0 93.125 93.125 0 208 0s208 93.125 208 208c0 48.741-16.765 93.566-44.843 129.024l133.826 134.018c9.366 9.379 9.355 24.575-.025 33.941-9.379 9.366-24.575 9.355-33.941-.025L337.238 370.987C301.747 399.167 256.839 416 208 416 93.125 416 0 322.875 0 208z"></path>
            </svg>
          </span>
        </a>
      </span>
    </div>
  </div>
</nav>

<script>
  const desktopNavParents = document.querySelectorAll('#site-navigation .menu-item-has-children');
  desktopNavParents.forEach((parent) => {
    const link = parent.querySelector(':scope > a');
    link?.addEventListener('click', (event) => {
      if (!window.matchMedia('(max-width: 768px)').matches) {
        event.preventDefault();
        desktopNavParents.forEach((otherParent) => {
          if (otherParent !== parent) {
            otherParent.classList.remove('menu-open');
          }
        });
        parent.classList.toggle('menu-open');
      }
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }
    if (!target.closest('#site-navigation')) {
      desktopNavParents.forEach((parent) => parent.classList.remove('menu-open'));
    }
  });

  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('mobile-open');
    mobileToggle.classList.toggle('is-open');
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
  });
</script>
