---
// FilterBar component placeholder
---
<div class="flex flex-wrap gap-2 py-4 items-center justify-center bg-white rounded shadow">
	<select class="border rounded px-3 py-2">
		<option>All Categories</option>
		<option>Govt</option>
		<option>Bank</option>
		<option>Admission</option>
		<option>Result</option>
		<option>Blog</option>
	</select>
	<select class="border rounded px-3 py-2">
		<option>Any Deadline</option>
		<option>Today</option>
		<option>3 days</option>
		<option>7 days</option>
		<option>15 days</option>
	</select>
	<select class="border rounded px-3 py-2">
		<option>Any Date</option>
		<option>Last 24hrs</option>
		<option>Last 3 days</option>
		<option>Last 7 days</option>
	</select>
	<button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Search</button>
</div>
