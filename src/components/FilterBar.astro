---
import { getCategoryLabelBn } from '../lib/content-utils';

const { categories = [] } = Astro.props;
---

<form id="filter-form" class="mb-6 grid gap-3 border border-gray-300 bg-white p-3 md:grid-cols-4">
  <select id="filter-category" class="rounded border border-gray-300 px-3 py-2 text-sm">
    <option value="">সব ক্যাটাগরি</option>
    {categories.map((category) => (
      <option value={category}>{getCategoryLabelBn(category)}</option>
    ))}
  </select>

  <select id="filter-deadline" class="rounded border border-gray-300 px-3 py-2 text-sm">
    <option value="">যেকোনো ডেডলাইন</option>
    <option value="today">আজ</option>
    <option value="3">৩ দিন</option>
    <option value="7">৭ দিন</option>
    <option value="15">১৫ দিন</option>
  </select>

  <select id="filter-date" class="rounded border border-gray-300 px-3 py-2 text-sm">
    <option value="">যেকোনো প্রকাশ তারিখ</option>
    <option value="1">শেষ ২৪ ঘণ্টা</option>
    <option value="3">শেষ ৩ দিন</option>
    <option value="7">শেষ ৭ দিন</option>
  </select>

  <button type="submit" class="rounded bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">খুঁজুন</button>
</form>
