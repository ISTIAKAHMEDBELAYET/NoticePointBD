---
const { post } = Astro.props;
const fm = post?.frontmatter ?? {};
const href = fm.slug ? `/${fm.slug}/` : '#';
const categories = Array.isArray(fm.categories) ? fm.categories : [];
---

<article
  class="overflow-hidden rounded-lg bg-white shadow-sm"
  data-post-card
  data-categories={categories.join(',')}
  data-date={fm.date ?? ''}
  data-deadline={fm.deadline ?? ''}
>
  <div class="p-4">
    <h2 class="mb-2 text-2xl font-bold leading-snug text-blue-700">
      <a class="hover:underline" href={href}>{fm.title ?? 'Untitled post'}</a>
    </h2>
    <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-gray-500">
      {fm.date && <span>{fm.date}</span>}
      {fm.type && <span class="rounded bg-blue-100 px-2 py-0.5 text-blue-700">{fm.type}</span>}
      {categories.map((category) => (
        <a href={`/category/${category}/`} class="rounded bg-gray-100 px-2 py-0.5 text-gray-700 hover:bg-gray-200">
          {category}
        </a>
      ))}
      {fm.hot && <span class="rounded bg-red-100 px-2 py-0.5 text-red-700">Hot</span>}
    </div>

    {fm.image && (
      <a href={href}>
        <img
          src={fm.image}
          alt={fm.imageAlt ?? fm.title ?? 'Post image'}
          class="mb-4 h-56 w-full rounded object-cover md:h-[360px]"
          loading="lazy"
        />
      </a>
    )}

    <div class="mb-2 flex flex-wrap gap-6 text-sm">
      {fm.vacancies && (
        <span>
          <strong>Podir Sonkha:</strong> {fm.vacancies}
        </span>
      )}
      {fm.deadline && (
        <span>
          <strong>Avedon Shesh Tarikh:</strong> {fm.deadline}
        </span>
      )}
      {fm.resultDate && (
        <span>
          <strong>Folafol Date:</strong> {fm.resultDate}
        </span>
      )}
    </div>

    <p class="text-sm text-gray-700">{fm.description ?? ''}</p>
    <a href={href} class="mt-3 inline-block font-semibold text-blue-700 hover:underline">
      Bistharito Porun -&gt;
    </a>
  </div>
</article>
