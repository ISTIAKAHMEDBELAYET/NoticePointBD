---
import { getCategoryLabelBn } from '../lib/content-utils';

const { post } = Astro.props;
const fm = post?.frontmatter ?? {};
const href = fm.slug ? `/${fm.slug}/` : '#';
const categories = Array.isArray(fm.categories) ? fm.categories : [];
---

<article
  class="overflow-hidden rounded border border-gray-200 bg-white"
  data-post-card
  data-categories={categories.join(',')}
  data-date={fm.date ?? ''}
  data-deadline={fm.deadline ?? ''}
>
  <div class="p-4 md:p-5">
    <h2 class="mb-2 text-2xl font-bold leading-snug text-blue-700 md:text-[1.85rem]">
      <a class="hover:underline" href={href}>{fm.title ?? 'Untitled post'}</a>
    </h2>
    <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-gray-600">
      {fm.date && <span>{fm.date}</span>}
      {fm.type && <span class="rounded bg-blue-100 px-2 py-0.5 text-blue-700">{fm.type === 'job' ? 'চাকরি' : fm.type}</span>}
      {categories.map((category) => (
        <a href={`/category/${category}/`} class="rounded bg-gray-100 px-2 py-0.5 text-gray-700 hover:bg-gray-200">
          {getCategoryLabelBn(category)}
        </a>
      ))}
      {fm.hot && <span class="rounded bg-red-100 px-2 py-0.5 text-red-700">হট</span>}
    </div>

    {fm.image && (
      <a href={href}>
        <img
          src={fm.image}
          alt={fm.imageAlt ?? fm.title ?? 'Post image'}
          class="mb-4 h-56 w-full object-cover md:h-[420px]"
          loading="lazy"
        />
      </a>
    )}

    <div class="mb-2 flex flex-wrap gap-6 text-sm text-gray-800">
      {fm.vacancies && (
        <span>
          <strong>পদের সংখ্যা:</strong> {fm.vacancies}
        </span>
      )}
      {fm.deadline && (
        <span>
          <strong>আবেদনের শেষ তারিখ:</strong> {fm.deadline}
        </span>
      )}
      {fm.resultDate && (
        <span>
          <strong>ফলাফল প্রকাশ:</strong> {fm.resultDate}
        </span>
      )}
    </div>

    <p class="text-sm text-gray-700">{fm.description ?? ''}</p>
    <a href={href} class="mt-3 inline-block font-semibold text-blue-700 hover:underline">
      বিস্তারিত পড়ুন -&gt;
    </a>
  </div>
</article>
