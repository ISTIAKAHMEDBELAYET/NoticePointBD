---
import { getCategoryLabelBn } from '../lib/content-utils';

const { post } = Astro.props;
const fm = post?.frontmatter ?? {};
const href = fm.slug ? `/${fm.slug}/` : '#';
const categories = Array.isArray(fm.categories) ? fm.categories : [];
---

<article
  class="np-panel np-hover np-fade-up overflow-hidden rounded-[10px]"
  data-post-card
  data-categories={categories.join(',')}
  data-date={fm.date ?? ''}
  data-deadline={fm.deadline ?? ''}
  data-title={String(fm.title ?? '').toLowerCase()}
  data-description={String(fm.description ?? '').toLowerCase()}
>
  <div class="p-5">
    <h2 class="mb-2 text-[27px] font-bold leading-[1.3] text-blue-700 md:text-[32px]">
      <a class="hover:underline" href={href}>{fm.title ?? 'Untitled post'}</a>
    </h2>
    <div class="mb-3 flex flex-wrap items-center gap-2 text-[16px] text-gray-600">
      {fm.date && <span>{fm.date}</span>}
      {fm.type && <span class="rounded bg-blue-100 px-2 py-0.5 text-blue-700">{fm.type === 'job' ? 'চাকরি' : fm.type}</span>}
      {categories.map((category) => (
        <a href={`/category/${category}/`} class="rounded bg-gray-100 px-2 py-0.5 text-gray-700 hover:bg-gray-200">
          {getCategoryLabelBn(category)}
        </a>
      ))}
      {/* Removed 'হট' badge from all post cards except in Hot Jobs section */}
    </div>

    {fm.image && (
      <a href={href}>
        <img
          src={fm.image}
          alt={fm.imageAlt ?? fm.title ?? 'Post image'}
          class="mb-4 h-56 w-full object-cover md:h-[430px]"
          loading="lazy"
        />
      </a>
    )}

    <div class="mb-3 flex flex-wrap gap-6 text-[17px] text-gray-800">
      {fm.vacancies && (
        <span>
          <strong>পদের সংখ্যা:</strong> {fm.vacancies}
        </span>
      )}
      {fm.deadline && (
        <span>
          <strong>আবেদনের শেষ তারিখ:</strong> {fm.deadline}
        </span>
      )}
      {fm.resultDate && (
        <span>
          <strong>ফলাফল প্রকাশ:</strong> {fm.resultDate}
        </span>
      )}
    </div>

    <p class="text-[17px] text-gray-700">{fm.description ?? ''}</p>
    <a href={href} class="mt-3 inline-block text-[17px] font-semibold text-blue-700 hover:underline">
      বিস্তারিত পড়ুন -&gt;
    </a>
  </div>
</article>
